# ──────────────────────────────────────────────
# GeminiMCP — example environment configuration
# Copy to .env and fill in the required values.
# ──────────────────────────────────────────────

# ── Required ───────────────────────────────────

# Google AI Studio or Vertex AI key
GEMINI_API_KEY=


# ── Models ─────────────────────────────────────

# Default model for gemini_ask.
# Tier aliases (resolved to latest live model at startup):
#   pro / gemini-pro | flash / gemini-flash | flash-lite / gemini-flash-lite
# Or pass an explicit model ID, e.g. gemini-2.5-pro-exp-03-25
GEMINI_MODEL=gemini-pro

# Default model for gemini_search (Google-Search grounded queries).
GEMINI_SEARCH_MODEL=gemini-flash-lite


# ── Inference ──────────────────────────────────

# Sampling temperature for gemini_ask. Must be 0.0–1.0.
GEMINI_TEMPERATURE=1.0

# System prompt injected into every gemini_ask call (unless overridden per-call).
# Leave blank to use the built-in code-review default.
GEMINI_SYSTEM_PROMPT=

# System prompt injected into every gemini_search call.
# Leave blank to use the built-in search-assistant default.
GEMINI_SEARCH_SYSTEM_PROMPT=

# Enable extended thinking mode for supported models (true/false).
GEMINI_ENABLE_THINKING=true

# Default thinking depth for gemini_ask: minimal | low | medium | high
GEMINI_THINKING_LEVEL=high

# Default thinking depth for gemini_search: minimal | low | medium | high
GEMINI_SEARCH_THINKING_LEVEL=low

# Billing service tier: flex | standard | priority
GEMINI_SERVICE_TIER=standard

# HTTP client timeout for Gemini API calls (Go duration, e.g. 90s, 2m).
GEMINI_TIMEOUT=90s


# ── Transport ──────────────────────────────────

# Set to true to start an HTTP/SSE transport instead of (or alongside) stdio.
# Alternatively pass --transport=http on the command line.
GEMINI_ENABLE_HTTP=false

# Bind address for the HTTP server.
GEMINI_HTTP_ADDRESS=:8080

# MCP endpoint path.
GEMINI_HTTP_PATH=/mcp

# Stateless mode — do not keep session state across requests.
GEMINI_HTTP_STATELESS=false

# SSE heartbeat interval (Go duration, e.g. 30s). Empty = disabled.
GEMINI_HTTP_HEARTBEAT=

# Enable CORS on the HTTP transport.
GEMINI_HTTP_CORS_ENABLED=true

# Comma-separated list of allowed CORS origins. Defaults to * (all).
GEMINI_HTTP_CORS_ORIGINS=*


# ── Authentication (HTTP transport only) ───────

# Enable JWT Bearer-token authentication. Requires GEMINI_AUTH_SECRET_KEY.
GEMINI_AUTH_ENABLED=false

# Secret key used to sign and verify JWTs. Minimum 32 characters.
# Generate one: openssl rand -hex 32
GEMINI_AUTH_SECRET_KEY=


# ── GitHub ─────────────────────────────────────

# Personal access token for GitHub API calls (github_* parameters).
# Required for private repos; optional for public repos.
# Scopes needed: repo (or contents:read + pull_requests:read for fine-grained PATs).
GEMINI_GITHUB_TOKEN=

# Override GitHub API base URL (for GitHub Enterprise).
# Leave blank to use https://api.github.com
GEMINI_GITHUB_API_BASE_URL=

# Max number of files fetched per github_files call.
GEMINI_MAX_GITHUB_FILES=20

# Max bytes per individual file fetched from GitHub.
GEMINI_MAX_GITHUB_FILE_SIZE=1048576

# Max bytes of a unified diff payload (PR diff, commit patch, compare diff).
# Large diffs are truncated at hunk boundaries to keep context valid.
GEMINI_MAX_GITHUB_DIFF_BYTES=512000

# Max commits fetched per github_commits call.
GEMINI_MAX_GITHUB_COMMITS=10

# Max PR review comments fetched when github_pr is used.
GEMINI_MAX_GITHUB_PR_REVIEW_COMMENTS=50


# ── File Handling (stdio only) ─────────────────

# Max bytes for a local file read via file_paths.
GEMINI_MAX_FILE_SIZE=10485760

# Restrict local file reads to this directory (security sandbox).
# Leave blank to allow any path the process can read.
GEMINI_FILE_READ_BASE_DIR=


# ── Retry ──────────────────────────────────────

# Max retry attempts for GitHub API calls.
GEMINI_MAX_RETRIES=2

# Initial backoff delay before first retry (Go duration).
GEMINI_INITIAL_BACKOFF=1s

# Maximum backoff delay (exponential + full jitter).
GEMINI_MAX_BACKOFF=10s
